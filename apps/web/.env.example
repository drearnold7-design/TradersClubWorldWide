# .env.example — every environment variable needed across all 10 phases
# Copy to .env.local for development, and set the same in Netlify's
# environment variables UI for production/preview deploys.

# --- Supabase (Phase 1/2) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to the browser

# --- Site (Phase 3/5) ---
NEXT_PUBLIC_SITE_URL=https://tradersclubworldwide.com
NEXT_PUBLIC_CURRENT_EVENT_ID=       # UUID of the active `events` row for the Aug 15-23 trip

# --- Stripe (Phase 5) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Whop (Phase 7) ---
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
NEXT_PUBLIC_WHOP_COURSE_ACCESS_PASS_ID=
NEXT_PUBLIC_WHOP_COURSE_PLAN_ID=
NEXT_PUBLIC_WHOP_COURSE_URL=

# --- Email / SMS (referenced in original spec — wire in when ready) ---
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Analytics (Phase 9) ---
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
